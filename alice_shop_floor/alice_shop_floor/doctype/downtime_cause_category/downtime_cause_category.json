{
  "name": "Downtime Cause Category",
  "doctype": "DocType",
  "module": "Alice Shop Floor",
  "autoname": "field:category_name",
  "fields": [
    {"fieldname": "category_name", "fieldtype": "Data",      "label": "Category Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "root_cause_group", "fieldtype": "Select", "label": "Root Cause Group", "in_list_view": 1,
     "options": "Machine\nOperator\nMaterial\nProcess\nExternal\nUnknown"},
    {"fieldname": "description",   "fieldtype": "Small Text","label": "Description"},
    {"fieldname": "recommended_action","fieldtype": "Small Text","label": "Default Recommended Action"},
    {"fieldname": "is_active",     "fieldtype": "Check",     "label": "Active", "default": "1"}
  ],
  "permissions": [
    {"role": "Manufacturing Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "System Manager",        "read": 1, "write": 1, "create": 1, "delete": 1}
  ]
}
