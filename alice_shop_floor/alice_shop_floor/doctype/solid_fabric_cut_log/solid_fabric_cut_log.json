{
 "name": "Solid Fabric Cut Log",
 "doctype": "DocType",
 "module": "Alice Shop Floor",
 "description": "Tracks the cutting of solid (non-printed) fabric pieces from rolls. Each entry records which roll(s) a Work Order's pieces were cut from, enabling dye-lot traceability and alerting when a WO spans two rolls (dye-lot bridge risk).",
 "autoname": "format:SFCL-{work_order}-{#####}",
 "field_order": [
  "work_order","production_item","cut_bundle","col_break_1",
  "cut_date","cut_by","status",
  "section_fabric",
  "fabric_item","fabric_description","col_break_2",
  "total_rolls_used","dye_lot_bridge_detected",
  "section_rolls",
  "rolls",
  "section_notes",
  "notes","supervisor_notes"
 ],
 "fields": [
  {
   "fieldname": "work_order",
   "fieldtype": "Link",
   "label": "Work Order",
   "options": "Work Order",
   "reqd": 1,
   "in_list_view": 1,
   "search_index": 1
  },
  {
   "fieldname": "production_item",
   "fieldtype": "Data",
   "label": "Item",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "cut_bundle",
   "fieldtype": "Link",
   "label": "Cut Bundle",
   "options": "Cut Bundle",
   "in_list_view": 0
  },
  {
   "fieldname": "col_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "cut_date",
   "fieldtype": "Date",
   "label": "Cut Date",
   "reqd": 1,
   "default": "Today",
   "in_list_view": 1
  },
  {
   "fieldname": "cut_by",
   "fieldtype": "Link",
   "label": "Cut By",
   "options": "User",
   "read_only": 1
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Draft\nConfirmed\nBridge Alert",
   "default": "Draft",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "section_fabric",
   "fieldtype": "Section Break",
   "label": "Fabric Details"
  },
  {
   "fieldname": "fabric_item",
   "fieldtype": "Link",
   "label": "Fabric Item",
   "options": "Item",
   "in_list_view": 0
  },
  {
   "fieldname": "fabric_description",
   "fieldtype": "Data",
   "label": "Fabric Description",
   "read_only": 1,
   "fetch_from": "fabric_item.item_name"
  },
  {
   "fieldname": "col_break_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "total_rolls_used",
   "fieldtype": "Int",
   "label": "Total Rolls Used",
   "read_only": 1,
   "default": "0",
   "description": "Auto-calculated from the Rolls table"
  },
  {
   "fieldname": "dye_lot_bridge_detected",
   "fieldtype": "Check",
   "label": "Dye-Lot Bridge Detected",
   "default": "0",
   "read_only": 1,
   "description": "Automatically set when pieces come from 2+ different dye lots"
  },
  {
   "fieldname": "section_rolls",
   "fieldtype": "Section Break",
   "label": "Roll Trace"
  },
  {
   "fieldname": "rolls",
   "fieldtype": "Table",
   "label": "Rolls Used",
   "options": "Solid Cut Roll",
   "description": "One row per roll — enter roll ID, dye lot, and which piece types were cut from it"
  },
  {
   "fieldname": "section_notes",
   "fieldtype": "Section Break",
   "label": "Notes",
   "collapsible": 1
  },
  {
   "fieldname": "notes",
   "fieldtype": "Small Text",
   "label": "Cutter Notes"
  },
  {
   "fieldname": "supervisor_notes",
   "fieldtype": "Small Text",
   "label": "Supervisor Notes"
  }
 ],
 "permissions": [
  {"role": "System Manager",       "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "Shop Floor Supervisor","read": 1, "write": 1, "create": 1},
  {"role": "Shop Floor Cutter",    "read": 1, "write": 1, "create": 1}
 ],
 "sort_field": "cut_date",
 "sort_order": "DESC",
 "creation": "2026-05-13 00:00:00",
 "modified": "2026-05-13 00:00:00",
 "modified_by": "Administrator",
 "owner": "Administrator",
 "actions": [],
 "links": []
}
