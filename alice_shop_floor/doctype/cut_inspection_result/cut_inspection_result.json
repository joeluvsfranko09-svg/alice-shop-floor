{
  "name": "Cut Inspection Result",
  "doctype": "DocType",
  "module": "Alice Shop Floor",
  "autoname": "CIR-{work_order}-{##}",
  "sort_field": "inspected_at",
  "sort_order": "DESC",
  "title_field": "work_order",
  "fields": [
    {
      "fieldname": "work_order",
      "fieldtype": "Link",
      "options": "Work Order",
      "label": "Work Order",
      "reqd": 1,
      "in_list_view": 1,
      "search_index": 1
    },
    {
      "fieldname": "fabric_lot",
      "fieldtype": "Data",
      "label": "Fabric Lot",
      "in_list_view": 1
    },
    {
      "fieldname": "overall_result",
      "fieldtype": "Select",
      "label": "Overall Result",
      "options": "Pending\nPass\nFail\nError",
      "default": "Pending",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "inspected_at",
      "fieldtype": "Datetime",
      "label": "Inspected At",
      "in_list_view": 1
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "cognex_job_id",
      "fieldtype": "Data",
      "label": "Cognex Job ID",
      "read_only": 1
    },
    {
      "fieldname": "triggered_by",
      "fieldtype": "Link",
      "options": "User",
      "label": "Triggered By"
    },
    {
      "fieldname": "section_counts",
      "fieldtype": "Section Break",
      "label": "Deviation Counts"
    },
    {
      "fieldname": "deviation_count_minor",
      "fieldtype": "Int",
      "label": "Minor Deviations",
      "default": 0,
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "deviation_count_major",
      "fieldtype": "Int",
      "label": "Major Deviations",
      "default": 0,
      "read_only": 1
    },
    {
      "fieldname": "deviation_count_critical",
      "fieldtype": "Int",
      "label": "Critical Deviations",
      "default": 0,
      "read_only": 1
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "panels_inspected",
      "fieldtype": "Int",
      "label": "Panels Inspected",
      "default": 0,
      "read_only": 1
    },
    {
      "fieldname": "panels_passed",
      "fieldtype": "Int",
      "label": "Panels Passed",
      "default": 0,
      "read_only": 1
    },
    {
      "fieldname": "section_map",
      "fieldtype": "Section Break",
      "label": "Cut Deviation Map"
    },
    {
      "fieldname": "deviation_map",
      "fieldtype": "Table",
      "label": "Deviation Map",
      "options": "Cut Deviation Map"
    },
    {
      "fieldname": "section_notes",
      "fieldtype": "Section Break",
      "label": "Notes"
    },
    {
      "fieldname": "fail_reason",
      "fieldtype": "Small Text",
      "label": "Fail Reason",
      "read_only": 1
    },
    {
      "fieldname": "error_message",
      "fieldtype": "Small Text",
      "label": "Error Message",
      "read_only": 1
    },
    {
      "fieldname": "supervisor_override",
      "fieldtype": "Check",
      "label": "Supervisor Override (Force Pass)",
      "default": 0
    },
    {
      "fieldname": "override_notes",
      "fieldtype": "Small Text",
      "label": "Override Notes",
      "depends_on": "eval:doc.supervisor_override==1"
    },
    {
      "fieldname": "overridden_by",
      "fieldtype": "Link",
      "options": "User",
      "label": "Overridden By",
      "read_only": 1
    },
    {
      "fieldname": "overridden_at",
      "fieldtype": "Datetime",
      "label": "Overridden At",
      "read_only": 1
    }
  ],
  "permissions": [
    {"role": "Manufacturing Manager", "read": 1, "write": 1, "create": 1},
    {"role": "Manufacturing User", "read": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1}
  ]
}
