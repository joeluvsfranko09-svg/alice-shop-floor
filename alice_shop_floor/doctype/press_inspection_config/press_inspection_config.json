  {"fieldname":"max_poll_attempts","fieldtype":"Int","label":"Max Poll Attempts","default":"20","description":"Give up after N attempts with no result"},
  {"fieldname":"col_break_2","fieldtype":"Column Break"},
  {"fieldname":"enabled","fieldtype":"Check","label":"V6 Press QC Enabled","default":"1"},
  {"fieldname":"thresholds_section","fieldtype":"Section Break","label":"Defect Thresholds"},
  {"fieldname":"confidence_threshold","fieldtype":"Float","label":"Min Confidence Score","default":"0.80","description":"Cognex detections below this score are ignored"},
