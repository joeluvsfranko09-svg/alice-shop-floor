  {"fieldname":"max_shine_allowed","fieldtype":"Int","label":"Max Shine Marks","default":"2","description":"Shine = over-pressed sheen on fabric"},
  {"fieldname":"max_crease_miss_allowed","fieldtype":"Int","label":"Max Crease Misses","default":"1"},
  {"fieldname":"fail_on_any_burn","fieldtype":"Check","label":"Fail on Any Burn Mark","default":"1"}
