{
 "name": "Press Inspection Log",
 "doctype": "DocType",
 "module": "Alice Shop Floor",
 "description": "V6: Records the outcome of a Cognex camera inspection at the press machine. One log per press operation per Work Order piece. Pass gate: allows advancement to Final QC only when result is Pass or supervisor-overridden.",
 "autoname": "format:PRESSINSP-{work_order}-{#####}",
 "field_order": [
  "work_order","production_item","col_break_1","overall_result","confidence_score",
  "section_press","press_temperature_c","press_pressure_bar","dwell_time_sec","col_break_2",
  "cognex_job_id","inspected_at","triggered_by",
  "section_counts","defect_count_scorch","defect_count_shine","defect_count_crease","defect_count_burn",
  "col_break_3","image_capture",
  "section_defects","defect_map",
  "section_outcome","fail_reason","error_message",
  "section_override","supervisor_override","overridden_by","overridden_at","override_notes"
 ],
 "fields": [
  {"fieldname":"work_order","fieldtype":"Link","label":"Work Order","options":"Work Order","reqd":1,"in_list_view":1,"search_index":1},
  {"fieldname":"production_item","fieldtype":"Data","label":"Item","read_only":1,"in_list_view":1},
  {"fieldname":"col_break_1","fieldtype":"Column Break"},
  {"fieldname":"overall_result","fieldtype":"Select","label":"Result",
   "options":"Pending\nPass\nFail\nError","default":"Pending","reqd":1,"in_list_view":1},
  {"fieldname":"confidence_score","fieldtype":"Float","label":"Avg Confidence","read_only":1},
  {"fieldname":"section_press","fieldtype":"Section Break","label":"Press Parameters"},
  {"fieldname":"press_temperature_c","fieldtype":"Float","label":"Temperature (°C)","description":"Reported by press machine sensor"},
  {"fieldname":"press_pressure_bar","fieldtype":"Float","label":"Pressure (bar)"},
  {"fieldname":"dwell_time_sec","fieldtype":"Float","label":"Dwell Time (sec)"},
  {"fieldname":"col_break_2","fieldtype":"Column Break"},
  {"fieldname":"cognex_job_id","fieldtype":"Data","label":"Cognex Job ID","read_only":1},
  {"fieldname":"inspected_at","fieldtype":"Datetime","label":"Inspected At","read_only":1},
  {"fieldname":"triggered_by","fieldtype":"Link","label":"Triggered By","options":"User","read_only":1},
  {"fieldname":"section_counts","fieldtype":"Section Break","label":"Defect Counts"},
  {"fieldname":"defect_count_scorch","fieldtype":"Int","label":"Scorch Marks","default":"0","read_only":1},
  {"fieldname":"defect_count_shine","fieldtype":"Int","label":"Shine Marks","default":"0","read_only":1},
  {"fieldname":"defect_count_crease","fieldtype":"Int","label":"Crease Misses","default":"0","read_only":1},
  {"fieldname":"defect_count_burn","fieldtype":"Int","label":"Burn Marks","default":"0","read_only":1},
  {"fieldname":"col_break_3","fieldtype":"Column Break"},
  {"fieldname":"image_capture","fieldtype":"Attach Image","label":"Press Camera Capture","description":"Primary frame captured by the press camera"},
  {"fieldname":"section_defects","fieldtype":"Section Break","label":"Defect Map"},
  {"fieldname":"defect_map","fieldtype":"Table","label":"Defect Map","options":"Press Defect Map"},
  {"fieldname":"section_outcome","fieldtype":"Section Break","label":"Outcome"},
  {"fieldname":"fail_reason","fieldtype":"Small Text","label":"Fail Reason","read_only":1},
  {"fieldname":"error_message","fieldtype":"Small Text","label":"Error Message","read_only":1},
  {"fieldname":"section_override","fieldtype":"Section Break","label":"Supervisor Override","collapsible":1},
  {"fieldname":"supervisor_override","fieldtype":"Check","label":"Supervisor Override","default":"0"},
  {"fieldname":"overridden_by","fieldtype":"Link","label":"Overridden By","options":"User","read_only":1},
  {"fieldname":"overridden_at","fieldtype":"Datetime","label":"Overridden At","read_only":1},
  {"fieldname":"override_notes","fieldtype":"Small Text","label":"Override Notes"}
 ],
 "permissions": [
  {"role":"System Manager","read":1,"write":1,"create":1,"delete":1},
  {"role":"Shop Floor Supervisor","read":1,"write":1,"create":1},
  {"role":"Shop Floor QC","read":1,"write":1}
 ],
 "sort_field":"inspected_at","sort_order":"DESC",
 "creation":"2026-05-13 00:00:00","modified":"2026-05-13 00:00:00",
 "modified_by":"Administrator","owner":"Administrator","actions":[],"links":[]
}
