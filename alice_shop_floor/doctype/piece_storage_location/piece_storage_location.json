{
 "name": "Piece Storage Location",
 "doctype": "DocType",
 "module": "Alice Shop Floor",
 "description": "Physical rack-and-slot location where cut fabric pieces are stored pending kitting. The picker tablet uses this to display virtual light-assist (rack letter + slot number).",
 "autoname": "format:PSL-{rack}{slot}",
 "field_order": [
  "rack","slot","col_break_1",
  "location_label","is_active",
  "section_inventory",
  "item","item_name","col_break_2",
  "dye_lot","qty_available",
  "section_notes","notes"
 ],
 "fields": [
  {
   "fieldname": "rack",
   "fieldtype": "Data",
   "label": "Rack",
   "reqd": 1,
   "in_list_view": 1,
   "description": "Single letter A–Z identifying the rack column",
   "length": 2
  },
  {
   "fieldname": "slot",
   "fieldtype": "Int",
   "label": "Slot",
   "reqd": 1,
   "in_list_view": 1,
   "description": "Slot number within the rack (1–99)"
  },
  {
   "fieldname": "col_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "location_label",
   "fieldtype": "Data",
   "label": "Display Label",
   "read_only": 1,
   "description": "Auto-set to Rack + Slot, e.g. A-12"
  },
  {
   "fieldname": "is_active",
   "fieldtype": "Check",
   "label": "Active",
   "default": "1",
   "in_list_view": 1
  },
  {
   "fieldname": "section_inventory",
   "fieldtype": "Section Break",
   "label": "Current Inventory"
  },
  {
   "fieldname": "item",
   "fieldtype": "Link",
   "label": "Item",
   "options": "Item",
   "in_list_view": 1
  },
  {
   "fieldname": "item_name",
   "fieldtype": "Data",
   "label": "Item Name",
   "fetch_from": "item.item_name",
   "read_only": 1
  },
  {
   "fieldname": "col_break_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "dye_lot",
   "fieldtype": "Data",
   "label": "Dye Lot",
   "in_list_view": 1
  },
  {
   "fieldname": "qty_available",
   "fieldtype": "Float",
   "label": "Qty Available",
   "default": "0",
   "in_list_view": 1
  },
  {
   "fieldname": "section_notes",
   "fieldtype": "Section Break",
   "label": "Notes",
   "collapsible": 1
  },
  {
   "fieldname": "notes",
   "fieldtype": "Small Text",
   "label": "Notes"
  }
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "Shop Floor Supervisor", "read": 1, "write": 1, "create": 1},
  {"role": "Shop Floor Picker", "read": 1, "write": 1}
 ],
 "sort_field": "rack",
 "sort_order": "ASC",
 "creation": "2026-05-13 00:00:00",
 "modified": "2026-05-13 00:00:00",
 "modified_by": "Administrator",
 "owner": "Administrator",
 "actions": [],
 "links": []
}
