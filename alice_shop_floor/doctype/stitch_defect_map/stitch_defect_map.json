{
  "name": "Stitch Defect Map",
  "doctype": "DocType",
  "module": "Alice Shop Floor",
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "defect_index",
      "fieldtype": "Int",
      "label": "Defect #",
      "in_list_view": 1,
      "read_only": 1
    },
    {
      "fieldname": "defect_type",
      "fieldtype": "Select",
      "label": "Defect Type",
      "options": "Skipped Stitch\nBroken Stitch\nLoose Stitch\nUneven Tension\nPucker\nOther",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "severity",
      "fieldtype": "Select",
      "label": "Severity",
      "options": "Minor\nMajor\nCritical",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "seam_location",
      "fieldtype": "Data",
      "label": "Seam Location",
      "in_list_view": 1,
      "description": "e.g. Left Side Seam, Shoulder, Hemline"
    },
    {
      "fieldname": "x_mm",
      "fieldtype": "Float",
      "label": "X Position (mm)"
    },
    {
      "fieldname": "y_mm",
      "fieldtype": "Float",
      "label": "Y Position (mm)"
    },
    {
      "fieldname": "stitch_count_affected",
      "fieldtype": "Int",
      "label": "Stitches Affected"
    },
    {
      "fieldname": "confidence_score",
      "fieldtype": "Float",
      "label": "Confidence Score"
    },
    {
      "fieldname": "image_ref",
      "fieldtype": "Data",
      "label": "Image Crop Reference"
    }
  ]
}
